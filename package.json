{
  "name": "train-with-joe",
  "version": "0.1.0",
  "bin": {
    "backend": "backend/bin/backend.js"
  },
  "scripts": {
    "clean": "rimraf cdk.out coverage",
    "clean:web": "rimraf frontend/src/.dart_tool frontend/src/build frontend/coverage --glob frontend/src/.flutter*",
    "deploy": "cdk deploy --all --require-approval never --concurrency 5",
    "deploy:parallel": "bash scripts/parallel-deploy.sh",
    "destroy": "cdk destroy --all --force",
    "bootstrap": "npm run build:appsyncFunctions",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "predeploy": "node build.mjs && npm run clean:web",
    "presynth": "node build.mjs && npm run clean:web",
    "prepare": "husky",
    "pretest": "npm run lint && npm run build:appsyncFunctions",
    "prewatch": "node build.mjs && npm run clean:web",
    "synth": "cdk synth --all",
    "test": "vitest run --config vitest.config.ts --silent",
    "test:coverage": "vitest run --config vitest.config.ts --coverage --silent",
    "test:fast": "vitest run --config vitest.config.ts --testTimeout=30000 --exclude='**/*e2e*' --no-coverage",
    "test:unit": "vitest run --config vitest.config.ts --testNamePattern='(?!.*integration|.*e2e)' --no-coverage",
    "watch": "cdk watch --all --hotswap-fallback",
    "build:appsyncFunctions": "node build.mjs",
    "bt": "npm run lint:fix && npm run test:fast"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "aws-cdk": "^2.1115.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-vitest": "^7.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@aws-appsync/utils": "^2.1.1",
    "@aws-cdk/aws-cognito-identitypool-alpha": "^2.186.0-alpha.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1019.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1019.0",
    "@aws-sdk/client-dynamodb": "^3.1019.0",
    "@aws-sdk/client-lambda": "^3.1020.0",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/lib-dynamodb": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "aws-cdk-lib": "^2.244.0",
    "constructs": "^10.6.0",
    "glob": "^13.0.6",
    "stripe": "^22.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix --cache"
  }
}
